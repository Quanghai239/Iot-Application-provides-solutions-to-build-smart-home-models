<!-- res/drawable/button_border.xml -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <solid android:color="#ffffff" /> <!-- Màu nền của khung -->
    <stroke
        android:width="2dp"
        android:color="#00ffff" /> <!-- Màu và độ dày của khung -->
    <padding
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp" />
    <corners android:radius="10dp" /> <!-- Góc bo tròn của khung -->
</shape>
